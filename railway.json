{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "pnpm install && pnpm build"
  },
  "deploy": {
    "startCommand": "node dist/migrate.js && node dist/index.js",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3
  }
}
