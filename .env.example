# Database (Railway MySQL 서비스에서 자동으로 제공됩니다)
DATABASE_URL=mysql://user:password@host:3306/railway

# JWT 세션 서명에 사용되는 비밀 키 (충분히 길고 랜덤한 문자열로 설정)
JWT_SECRET=change-this-to-a-long-random-secret

# 관리자 대시보드 로그인 비밀번호
ADMIN_PASSWORD=change-this-to-your-admin-password

# 실행 환경 (Railway에서는 자동으로 설정됩니다)
NODE_ENV=production

# 포트 (Railway에서는 자동으로 설정됩니다)
PORT=3000
